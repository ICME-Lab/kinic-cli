{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowJs": false,
    "checkJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@kinic/kinic-share": [
        "apps/kinic-portal/packages/kinic-share/src/index.ts"
      ],
      "@kinic/kinic-share/*": [
        "apps/kinic-portal/packages/kinic-share/src/*"
      ]
    }
  }
}
